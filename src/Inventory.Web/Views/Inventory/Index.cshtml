@using Inventory.Domain.Entities
@model Inventory.Domain.ViewModels.PaginatedList<InventoryTransaction>
@{
	Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between mb-3">
	<h3>Inventory Transactions</h3>

	<a asp-action="Create" class="btn btn-primary">
		Add Transaction
	</a>
</div>

<form method="get" class="mb-3 row g-2">
	<div class="col-md-4">
		<input name="search" class="form-control" placeholder="Search product code or name..." value="@ViewBag.Search" />
	</div>

	<div class="col-md-3">
		<div class="row g-2">
			<div class="col">
				<select name="type" class="form-select">
					<option value="">All types</option>
					<option value="Stock" selected="@(ViewBag.Type?.ToString() == "Stock" ? "selected" : null)">Stock</option>
					<option value="Order" selected="@(ViewBag.Type?.ToString() == "Order" ? "selected" : null)">Order</option>
				</select>
			</div>

			<div class="col">
				<select name="catalogueId" class="form-select">
					<option value="">All products</option>
					@if (ViewBag.Catalogues is IEnumerable<Catalogue> cats)
					{
						foreach (var c in cats)
						{
							<option value="@c.Id" selected="@(ViewBag.CatalogueId != null && ViewBag.CatalogueId == c.Id ? "selected" : null)">@c.Name</option>
						}
					}
				</select>
			</div>
		</div>
	</div>

	<div class="col-auto">
		<button class="btn btn-primary">Filter</button>
	</div>
</form>

<table class="table table-bordered table-striped">
	<thead class="table-dark">
		<tr>
			<th>Product</th>
			<th>Type</th>
			<th>Qty</th>
			<th>Date</th>
			<th>Action</th>
		</tr>
	</thead>

	<tbody>
		@foreach (var item in Model.Items)
		{
			<tr>
				<td>@item.Catalogue.Name</td>
				<td>@item.TransactionType</td>
				<td>@item.Quantity</td>
				<td>@item.TransactionDate.ToString("dd-MM-yyyy")</td>
				<td>
					<a asp-action="Delete"
					   asp-route-id="@item.Id"
					   class="btn btn-danger btn-sm">
						Delete
					</a>
				</td>
			</tr>
		}
	</tbody>
</table>