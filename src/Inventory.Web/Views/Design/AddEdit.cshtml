@using Inventory.Domain.ViewModels
@model MatchingVM

@{
	Layout = "~/Views/Shared/_Layout.cshtml";
	bool isEdit = Model?.DesignId > 0;
	ViewData["Title"] = isEdit ? "Edit Design" : "Add Design";
}

<div class="card">
	<div class="card-header d-flex justify-content-between align-items-center">
		<h5 class="mb-0">@(isEdit ? "Edit Matching" : "Add Matching")</h5>
		<a href="@Url.Action("Index", "Design")" class="btn btn-sm btn-outline-secondary">
			<i class="bi bi-arrow-left me-1"></i> Back
		</a>
	</div>

	<div class="card-body">
		@using (Html.BeginForm("Save", "Design", FormMethod.Post, new { id = "matchingForm" }))
		{
			@Html.AntiForgeryToken()
			@Html.HiddenFor(x => x.DesignId)

			<!-- ── Top Fields ── -->
			<div class="row mb-3">
				<div class="col-md-3">
					<label class="form-label fw-semibold">Quality</label>
					<input asp-for="Quality" class="form-control" name="Quality" placeholder="Enter Quality" />
					<span asp-validation-for="Quality" class="text-danger"></span>
				</div>
				<div class="col-md-3">
					<label class="form-label fw-semibold">Design No</label>
					<input asp-for="DesignNo" class="form-control" name="DesignNo" placeholder="Enter Design No." />
					<span asp-validation-for="DesignNo" class="text-danger"></span>
				</div>
				<div class="col-md-3">
					<label class="form-label fw-semibold">Party</label>
					<select asp-for="PartyId" asp-items="ViewBag.PartyList" class="form-select">
						<option value="">-- Select Party --</option>
					</select>
				</div>
				<div class="col-md-3">
					<label class="form-label fw-semibold">Date</label>
					<input asp-for="Date" type="date" class="form-control" name="Date" />
					<span asp-validation-for="Date" class="text-danger"></span>
				</div>
			</div>

			<!-- ── Plates / Matching Count + Generate ── -->
			<div class="row g-3 align-items-end mb-4">
				<div class="col-md-3">
					<label class="form-label fw-semibold">
						Plates
						@if (isEdit)
						{
							<span class="badge bg-danger ms-1">Locked</span>
						}
					</label>
					<input type="number" class="form-control @Html.Raw(isEdit ? "bg-light" : "")"
						   id="Plates"
						   value="@(Model?.Plates > 0 ? Model.Plates : 4)"
						   min="1" max="20"
						   @(isEdit ? "readonly" : "") />
				</div>
				<div class="col-md-3">
					<label class="form-label fw-semibold">
						Matching
						@if (isEdit)
						{
							<span class="badge bg-danger ms-1">Locked</span>
						}
					</label>
					<input type="number" class="form-control @Html.Raw(isEdit ? "bg-light" : "")"
						   id="Matching"
						   value="@(Model?.Matching > 0 ? Model.Matching : 6)"
						   min="1" max="12"
						   @(isEdit ? "readonly" : "") />
				</div>
				@if (!isEdit)
				{
					<div class="col-md-2">
						<button type="button" class="btn btn-primary w-100" id="btnGenerate">
							Generate Table
						</button>
					</div>
				}
			</div>

			<hr class="m-0" />

			<!-- ── Table ── -->
			<div class="card d-none mt-3" id="tableWrap">
				<div class="table-responsive">
					<table class="table table-bordered align-middle text-center">
						<thead class="sticky-top">
							<tr id="headMain">
								<th rowspan="2" class="text-start align-bottom bg-light" style="min-width:200px;">Plate Name</th>
								<th rowspan="2" class="align-bottom bg-light" style="min-width:80px;">No</th>
							</tr>
							<tr id="headSub"></tr>
						</thead>
						<tbody id="tableBody"></tbody>
					</table>
				</div>
			</div>

			<!-- ── Footer ── -->
			<div class="d-flex justify-content-end gap-2 mt-3">
				<a href="@Url.Action("Index", "Design")" class="btn btn-secondary">Cancel</a>
				<button type="submit" class="btn btn-success" id="btnSave" disabled>
					@(isEdit ? "Update" : "Save")
				</button>
			</div>
		}
	</div>
</div>




@section Scripts {
	@{
		await Html.RenderPartialAsync("_ValidationScriptsPartial");
	}

	<script>
		(function () {
			// ── DOM refs ──────────────────────────────────────────────────────
			const btnGenerate = document.getElementById('btnGenerate');
			const tableWrap   = document.getElementById('tableWrap');
			const headMain    = document.getElementById('headMain');
			const headSub     = document.getElementById('headSub');
			const tableBody   = document.getElementById('tableBody');
			const btnSave     = document.getElementById('btnSave');

			// ── Server data injected from Razor ──────────────────────────────
			// null on Add mode, full rows array on Edit mode
			const serverRows = @Html.Raw(Model?.Rows != null && Model.Rows.Count > 0
				? System.Text.Json.JsonSerializer.Serialize(Model.Rows)
				: "null"
									);

			const isEdit = @Html.Raw(isEdit ? "true" : "false");

			// ── AUTO-BUILD on Edit mode ───────────────────────────────────────
			if (isEdit && serverRows && serverRows.length > 0) {
				const mCount = serverRows[0].Matchings ? serverRows[0].Matchings.length : 0;
				buildTable(mCount, serverRows);
			}

			// ── Generate button (Add mode only) ──────────────────────────────
			if (btnGenerate) {
				btnGenerate.addEventListener('click', function () {
					const plates   = parseInt(document.getElementById('Plates').value, 10) || 4;
					const matching = parseInt(document.getElementById('Matching').value, 10) || 6;
					buildTable(matching, null, plates);
				});
			}

			// ── Core build function ───────────────────────────────────────────
			// mCount      = number of matching columns
			// existingRows = array from server (edit) or null (add)
			// plates      = row count when adding fresh
			function buildTable(mCount, existingRows, plates) {

				// Reset header — keep first 2 fixed <th> (Plate Name, No)
				while (headMain.children.length > 2)
					headMain.removeChild(headMain.lastChild);
				headSub.innerHTML   = '';
				tableBody.innerHTML = '';

				// Matching column headers
				for (let m = 0; m < mCount; m++) {
					const th = document.createElement('th');
					th.textContent = 'M' + (m + 1);
					th.colSpan = 2;
					th.classList.add('bg-light', 'fw-bold');
					headMain.appendChild(th);

					['Color', 'Qty'].forEach(label => {
						const sub = document.createElement('th');
						sub.textContent = label;
						sub.classList.add('bg-light', 'fw-bold');
						headSub.appendChild(sub);
					});
				}

				// Rows
				const rowCount = existingRows ? existingRows.length : (plates || 4);

				for (let r = 0; r < rowCount; r++) {
					const row = existingRows ? existingRows[r] : null;
					const tr  = document.createElement('tr');

					// ── KEY: hidden DesignPlateId for edit (0 = new row) ──────
					tr.appendChild(hiddenInput(`Rows[${r}].DesignPlateId`,
						row?.DesignPlateId ?? 0));

					// Plate Name
					tr.innerHTML += `
						<td class="text-start">
							<input class="form-control form-control-sm"
								   style="min-width:180px"
								   name="Rows[${r}].PlateName"
								   value="${escHtml(row?.PlateName)}"
								   placeholder="Enter Plate Name" />
						</td>`;

					// Plate No (display + hidden)
					const plateNo = row?.PlateNo ?? (r + 1);
					tr.innerHTML += `
						<td class="fw-semibold">
							${r + 1}
							<input type="hidden" name="Rows[${r}].PlateNo" value="${plateNo}" />
						</td>`;

					// Matching cells
					for (let m = 0; m < mCount; m++) {
						const cell = row?.Matchings?.[m] ?? null;

						// ── KEY: hidden DesignMatchingId (0 = new cell) ───────
						tr.appendChild(hiddenInput(
							`Rows[${r}].Matchings[${m}].DesignMatchingId`,
							cell?.DesignMatchingId ?? 0));

						tr.appendChild(hiddenInput(
							`Rows[${r}].Matchings[${m}].MatchingNo`, m + 1));

						tr.innerHTML += `
							<td>
								<input class="form-control form-control-sm"
									   style="min-width:120px"
									   name="Rows[${r}].Matchings[${m}].Colour"
									   value="${escHtml(cell?.Colour)}"
									   placeholder="Colour" />
							</td>
							<td>
								<input type="number"
									   class="form-control form-control-sm"
									   style="min-width:70px"
									   name="Rows[${r}].Matchings[${m}].Quantity"
									   value="${cell?.Quantity ?? ''}"
									   min="0" />
							</td>`;
					}

					tableBody.appendChild(tr);
				}

				tableWrap.classList.remove('d-none');
				btnSave.disabled = false;
			}

			// ── Helpers ───────────────────────────────────────────────────────

			// Create a hidden <input> element (avoids innerHTML injection issues)
			function hiddenInput(name, value) {
				const el = document.createElement('input');
				el.type  = 'hidden';
				el.name  = name;
				el.value = value ?? 0;
				return el;
			}

			// Safely escape values written into HTML attribute strings
			function escHtml(str) {
				if (str == null) return '';
				return String(str)
					.replace(/&/g, '&amp;')
					.replace(/"/g, '&quot;')
					.replace(/</g, '&lt;')
					.replace(/>/g, '&gt;');
			}

		})();
	</script>
}
