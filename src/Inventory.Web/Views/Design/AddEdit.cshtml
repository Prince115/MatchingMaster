@using Inventory.Domain.ViewModels
@model MatchingVM

@{
	Layout = "~/Views/Shared/_Layout.cshtml";
	bool isEdit = Model?.DesignId > 0;
	ViewData["Title"] = isEdit ? "Edit Design" : "Add Design";
}

<style>
    .input-error {
        border: 1px solid red !important;
        background-color: #ffe6e6;
    }
</style>

<div class="card">
	<div class="card-header d-flex justify-content-between align-items-center">
		<h5 class="mb-0">@(isEdit ? "Edit Matching" : "Add Matching")</h5>
		<a href="@Url.Action("Index", "Design")" class="btn btn-sm btn-outline-secondary">
			<i class="bi bi-arrow-left me-1"></i> Back
		</a>
	</div>

	<div class="card-body">
		@using (Html.BeginForm("Save", "Design", FormMethod.Post, new { id = "matchingForm" }))
		{
			@Html.AntiForgeryToken()
			@Html.HiddenFor(x => x.DesignId)

			<!-- ── Top Fields ── -->
			<div class="row mb-3">
				<div class="col-md-3">
					<label class="form-label fw-semibold">Design No</label>
					<input asp-for="DesignNo" class="form-control" name="DesignNo" placeholder="Enter Design No." />
					<span asp-validation-for="DesignNo" class="text-danger"></span>
				</div>
				<div class="col-md-3">
					<label class="form-label fw-semibold">Party</label>
					<select asp-for="PartyId" asp-items="ViewBag.PartyList" class="form-select">
						<option value="">-- Select Party --</option>
					</select>
				</div>
				<div class="col-md-3">
					<label class="form-label fw-semibold">Date</label>
					<input asp-for="Date" type="date" class="form-control" name="Date" />
					<span asp-validation-for="Date" class="text-danger"></span>
				</div>
			</div>

			<!-- ── Plates / Matching Count + Generate ── -->
			<div class="row g-3 align-items-end mb-4">
				<div class="col-md-3">
					<label class="form-label fw-semibold">
						Plates
						@if (isEdit)
						{
							<span class="badge bg-danger ms-1">Locked</span>
						}
					</label>
					<input type="number" class="form-control @Html.Raw(isEdit ? "bg-light" : "")"
						   id="Plates"
						   value="@(Model?.Plates > 0 ? Model.Plates : 4)"
						   min="1" max="20"
						   @(isEdit ? "readonly" : "") />
				</div>
				<div class="col-md-3">
					<label class="form-label fw-semibold">
						Matching
						@if (isEdit)
						{
							<span class="badge bg-danger ms-1">Locked</span>
						}
					</label>
					<input type="number" class="form-control @Html.Raw(isEdit ? "bg-light" : "")"
						   id="Matching"
						   value="@(Model?.Matching > 0 ? Model.Matching : 6)"
						   min="1" max="12"
						   @(isEdit ? "readonly" : "") />
				</div>
				@if (!isEdit)
				{
					<div class="col-md-2">
						<button type="button" class="btn btn-primary w-100" id="btnGenerate">
							Generate Table
						</button>
					</div>
				}

				<div class="col-md-2">
					<button type="button" class="btn btn-primary w-100" id="btnAddMatching">
						<i class="bi bi-plus"></i> Add Matching
					</button>
				</div>
			</div>

			<hr class="m-0" />

			<!-- ── Table ── -->
			<div class="card d-none mt-3" id="tableWrap">
				<div class="table-responsive">
					<table class="table table-bordered align-middle text-center">
						<thead class="sticky-top">
							<tr id="headMain">
								<th rowspan="2" class="text-start align-bottom bg-light" style="min-width:200px;">Plate Name</th>
								<th rowspan="2" class="align-bottom bg-light" style="min-width:80px;">No</th>
							</tr>
							<tr id="headSub"></tr>
						</thead>
						<tbody id="tableBody"></tbody>
					</table>
				</div>
			</div>

			<!-- ── Footer ── -->
			<div class="d-flex justify-content-end gap-2 mt-3">
				<a href="@Url.Action("Index", "Design")" class="btn btn-secondary">Cancel</a>
				<button type="submit" class="btn btn-success" id="btnSave" disabled>
					@(isEdit ? "Update" : "Save")
				</button>
			</div>
		}
	</div>
</div>




@section Scripts {
	@{
		await Html.RenderPartialAsync("_ValidationScriptsPartial");
	}

    <script>
        (function () {
            const btnGenerate    = document.getElementById('btnGenerate');
            const btnAddMatching = document.getElementById('btnAddMatching');
            const tableWrap      = document.getElementById('tableWrap');
            const headMain       = document.getElementById('headMain');
            const headSub        = document.getElementById('headSub');
            const tableBody      = document.getElementById('tableBody');
            const btnSave        = document.getElementById('btnSave');

            const serverRows = @Html.Raw(Model?.Rows != null && Model.Rows.Count > 0
                            ? System.Text.Json.JsonSerializer.Serialize(Model.Rows)
                            : "null");

            const isEdit = @Html.Raw(isEdit ? "true" : "false");

            // ── AUTO-BUILD on Edit mode ───────────────────────────────────────────
            if (isEdit && serverRows && serverRows.length > 0) {
                const mCount = serverRows[0].Matchings ? serverRows[0].Matchings.length : 0;
                buildTable(mCount, serverRows);
            }

            // ── Generate button (Add mode only) ──────────────────────────────────
            if (btnGenerate) {
                btnGenerate.addEventListener('click', function () {
                    const plates   = parseInt(document.getElementById('Plates').value, 10) || 4;
                    const matching = parseInt(document.getElementById('Matching').value, 10) || 6;
                    buildTable(matching, null, plates);
                });
            }

            // ── Add Matching button — preserves existing data ─────────────────────
            if (btnAddMatching) {
                btnAddMatching.addEventListener('click', function () {

                    const platesInput   = document.getElementById('Plates');
                    const matchingInput = document.getElementById('Matching');

                    const plates   = parseInt(platesInput.value,   10) || 4;
                    let   matching = parseInt(matchingInput.value, 10) || 6;

                    // ── STEP 1: Save all current input values ─────────────────
                    const savedData = saveCurrentTableData();

                    // ── STEP 2: Increment matching count ──────────────────────
                    matching += 1;
                    matchingInput.value = matching;

                    // ── STEP 3: Rebuild table with new column count ───────────
                    buildTable(matching, null, plates);

                    // ── STEP 4: Restore saved values back ─────────────────────
                    restoreTableData(savedData);
                    // New last column stays empty — user fills it in
                });
            }

            // ── Save current table data before rebuild ────────────────────────────
            function saveCurrentTableData() {
                const savedData = [];

                document.querySelectorAll('#tableBody tr').forEach((tr, r) => {

                    const row = {
                        plateId   : getVal(tr, `Rows[${r}].DesignPlateId`),
                        plateName : getVal(tr, `Rows[${r}].PlateName`),
                        plateNo   : getVal(tr, `Rows[${r}].PlateNo`),
                        matchings : []
                    };

                    let m = 0;
                    while (true) {
                        const matchingIdInput = tr.querySelector(`input[name="Rows[${r}].Matchings[${m}].DesignMatchingId"]`);
                        const colourInput     = tr.querySelector(`input[name="Rows[${r}].Matchings[${m}].Colour"]`);
                        if (!colourInput) break;

                        row.matchings.push({
                            designMatchingId : matchingIdInput ? matchingIdInput.value : 0,
                            colour           : colourInput.value
                        });
                        m++;
                    }

                    savedData.push(row);
                });

                return savedData;
            }

            // ── Restore saved data into rebuilt table ─────────────────────────────
            function restoreTableData(savedData) {
                savedData.forEach((row, r) => {
                    const tr = document.querySelector(`#tableBody tr:nth-child(${r + 1})`);
                    if (!tr) return;

                    // Restore plate fields
                    setVal(tr, `Rows[${r}].DesignPlateId`, row.plateId);
                    setVal(tr, `Rows[${r}].PlateName`,     row.plateName);
                    setVal(tr, `Rows[${r}].PlateNo`,        row.plateNo);

                    // Restore matching cells (existing ones only, new last column stays empty)
                    row.matchings.forEach((cell, m) => {
                        setVal(tr, `Rows[${r}].Matchings[${m}].DesignMatchingId`, cell.designMatchingId);
                        setVal(tr, `Rows[${r}].Matchings[${m}].Colour`,           cell.colour);
                    });
                });
            }

            // ── Core build function ───────────────────────────────────────────────
            function buildTable(mCount, existingRows, plates) {

                // Reset headers — keep first 2 fixed <th> (Plate Name, No)
                while (headMain.children.length > 2)
                    headMain.removeChild(headMain.lastChild);
                headSub.innerHTML   = '';
                tableBody.innerHTML = '';

                // Build matching column headers
                for (let m = 0; m < mCount; m++) {
                    const th = document.createElement('th');
                    th.textContent = 'M' + (m + 1);
                    th.classList.add('bg-light', 'fw-bold');
                    headMain.appendChild(th);

                    const sub = document.createElement('th');
                    sub.textContent = 'Color';
                    sub.classList.add('bg-light', 'fw-bold');
                    headSub.appendChild(sub);
                }

                // Build rows
                const rowCount = existingRows ? existingRows.length : (plates || 4);

                for (let r = 0; r < rowCount; r++) {
                    const row = existingRows ? existingRows[r] : null;
                    const tr  = document.createElement('tr');

                    // Hidden DesignPlateId (0 = new row)
                    tr.appendChild(hiddenInput(`Rows[${r}].DesignPlateId`, row?.DesignPlateId ?? 0));

                    // Plate Name
                    tr.innerHTML += `
                        <td class="text-start">
                            <input class="form-control form-control-sm"
                                   style="min-width:180px"
                                   name="Rows[${r}].PlateName"
                                   value="${escHtml(row?.PlateName)}"
                                   placeholder="Enter Plate Name" />
                        </td>`;

                    // Plate No
                    const plateNo = row?.PlateNo ?? (r + 1);
                    tr.innerHTML += `
                        <td class="fw-semibold">
                            ${r + 1}
                            <input type="hidden" name="Rows[${r}].PlateNo" value="${plateNo}" />
                        </td>`;

                    // Matching cells
                    for (let m = 0; m < mCount; m++) {
                        const cell = row?.Matchings?.[m] ?? null;

                        tr.appendChild(hiddenInput(
                            `Rows[${r}].Matchings[${m}].DesignMatchingId`,
                            cell?.DesignMatchingId ?? 0));

                        tr.appendChild(hiddenInput(
                            `Rows[${r}].Matchings[${m}].MatchingNo`, m + 1));

                        tr.innerHTML += `
                            <td>
                                <input class="form-control form-control-sm"
                                       style="min-width:120px"
                                       name="Rows[${r}].Matchings[${m}].Colour"
                                       value="${escHtml(cell?.Colour)}"
                                       placeholder="Colour" />
                            </td>`;
                    }

                    tableBody.appendChild(tr);
                }

                tableWrap.classList.remove('d-none');
                btnSave.disabled = false;
            }

            document.querySelector('form').addEventListener('submit', function (e) {
                let isValid = true;

                document.querySelectorAll('.input-error').forEach(el => el.classList.remove('input-error'));

                document.querySelectorAll('input[name$=".PlateName"]').forEach(input => {
                    if (!input.value.trim()) {
                        input.classList.add('input-error');
                        isValid = false;
                    }
                });

                document.querySelectorAll('input[name$=".Colour"]').forEach(input => {
                    if (!input.value.trim()) {
                        input.classList.add('input-error');
                        isValid = false;
                    }
                });

                if (!isValid) {
                    e.preventDefault();
                    alert("Please fill all Plate Name and Colour fields.");
                }
            });

            // Get input value by name inside a row
            function getVal(tr, name) {
                const el = tr.querySelector(`input[name="${name}"]`);
                return el ? el.value : '';
            }

            // Set input value by name inside a row
            function setVal(tr, name, value) {
                const el = tr.querySelector(`input[name="${name}"]`);
                if (el) el.value = value ?? '';
            }

            // Create hidden input element
            function hiddenInput(name, value) {
                const el = document.createElement('input');
                el.type  = 'hidden';
                el.name  = name;
                el.value = value ?? 0;
                return el;
            }

            // Escape HTML attribute values
            function escHtml(str) {
                if (str == null) return '';
                return String(str)
                    .replace(/&/g, '&amp;')
                    .replace(/"/g, '&quot;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;');
            }

        })();
    </script>
}
