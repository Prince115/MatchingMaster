@using Inventory.Domain.Entities
@model Catalogue
@{
    ViewData["Title"] = "Edit Product";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h3>Edit Product</h3>

<div class="card shadow-sm">
    <div class="card-body">

        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label class="form-label">Code</label>
                <input asp-for="Code" class="form-control" />
                <span asp-validation-for="Code" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Name</label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Packing</label>
                <input asp-for="Packing" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Remark</label>
                <textarea asp-for="Remark" class="form-control"></textarea>
            </div>

            <div class="mb-3">
                <label class="form-label">Photo</label>
                @if (!string.IsNullOrEmpty(Model.PhotoFileName))
                {
                    <div class="mb-2">
                        <img src="~/uploads/catalogues/@Model.PhotoFileName" style="max-height:120px;" class="img-thumbnail" />
                    </div>
                }
                <input type="file" name="photo" accept="image/*" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Document (PDF)</label>
                @if (!string.IsNullOrEmpty(Model.PdfFileName))
                {
                    <div class="mb-2">
                        <a class="btn btn-outline-secondary btn-sm" target="_blank" href="~/uploads/catalogues/@Model.PdfFileName">View current document</a>
                    </div>
                }
                <input type="file" name="pdf" accept="application/pdf" class="form-control" />
            </div>

            <button type="submit" class="btn btn-primary">
                Update
            </button>

            <a asp-action="Index" class="btn btn-secondary">
                Cancel
            </a>
        </form>

    </div>
</div>