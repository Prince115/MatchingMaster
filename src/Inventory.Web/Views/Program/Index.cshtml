@using Inventory.Domain.ViewModels
@model Inventory.Domain.ViewModels.PaginatedList<ProgramVM>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="card shadow-sm">
    <!-- Header -->
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h4 class="mb-0">Design</h4>

        <a asp-action="AddEdit" asp-controller="Program" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Add Program
        </a>
    </div>

    <div class="card-body">

        <!-- Filter -->
        <form method="get" class="row g-2 align-items-end mb-3">

            <div class="col-md-3">
                <label class="form-label fw-semibold">Party</label>
                <select name="PartyId"
                        class="form-select"
                        asp-items="ViewBag.PartyList">
                    <option value="">-- All Parties --</option>
                </select>
            </div>

            <div class="col-auto">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-funnel"></i> Filter
                </button>
            </div>

            <div class="col-auto">
                <a asp-action="Index" class="btn btn-secondary">
                    Reset
                </a>
            </div>

        </form>

        <!-- Table -->
        <div class="table-responsive">

            <table class="table table-bordered table-striped table-hover align-middle">

                <thead class="table-dark">
                    <tr>
                        <th>Program No.</th>
                        <th>Party</th>
                        <th>Design</th>
                        <th>Matching</th>
                        <th>Date</th>
                        <th class="text-center" width="180">Action</th>
                    </tr>
                </thead>

                <tbody>

                    @if (Model.Items.Any())
                    {
                        foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>@item.ProgramNo</td>
                                <td>@item.PartyName</td>
                                <td>@item.DesignNo</td>
                                <td>@item.TotalMatchings</td>
                                <td>@item.Date.ToString("dd-MM-yyyy")</td>

                                <td class="text-center">

                                    <a asp-controller="Program"
                                           asp-action="AddEdit"
                                           asp-route-id="@item.ProgramId"
                                           class="btn btn-warning btn-sm me-1">
                                        <i class="bi bi-pencil"></i>
                                    </a>

                                    <a asp-controller="Program"
                                           asp-action="Delete"
                                           asp-route-id="@item.ProgramId"
                                           class="btn btn-danger btn-sm"
                                           onclick="return confirm('Are you sure you want to delete this record?')">
                                        <i class="bi bi-trash"></i>
                                    </a>

                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted py-4">
                                No designs found
                            </td>
                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

    <!-- Pagination -->
    <div class="card-footer bg-white">

        <nav>
            <ul class="pagination mb-0">

                <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link"
                           asp-action="Index"
                           asp-route-page="@(Model.PageIndex - 1)"
                           asp-route-pageSize="@ViewBag.PageSize">
                        Previous
                    </a>
                </li>

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                        <a class="page-link"
                               asp-action="Index"
                               asp-route-page="@i"
                               asp-route-pageSize="@ViewBag.PageSize">
                            @i
                        </a>
                    </li>
                }

                <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                    <a class="page-link"
                           asp-action="Index"
                           asp-route-page="@(Model.PageIndex + 1)"
                           asp-route-pageSize="@ViewBag.PageSize">
                        Next
                    </a>
                </li>

            </ul>
        </nav>

    </div>

</div>
