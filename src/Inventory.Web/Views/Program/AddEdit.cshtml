	<script>
		window.preselectedMatchings = @Html.Raw(Json.Serialize(Model.SelectedMatchings));
		$(document).ready(function () {

		$('#designSelect').select2({
		theme: 'bootstrap-5',
		placeholder: 'Select Designs...',
		width: '100%'
		});

		$('#matchingSelect').select2({
		theme: 'bootstrap-5',
		placeholder: 'Select Matchings...',
		width: '100%'
		});

		let preselectedMatchings = window.preselectedMatchings || [];

		function loadMatchings(selectedIds, isEdit = false) {

		if (!selectedIds || selectedIds.length === 0) {
		$('#matchingSelect').empty().trigger('change');
		return;
		}

		$.get('/Program/GetMatchingByDesignIDCSV',
		{ DesignIDCSV: selectedIds.join(',') },
		function (data) {

		$('#matchingSelect').empty();

		data.forEach(item => {

		const value = item.designId + '|' + item.matchingNo;
		const text = "D" + item.designNo + " - M" + item.matchingNo;

		$('#matchingSelect').append(
		new Option(text, value, false, false)
		);
		});

		// ✅ EDIT MODE SELECT
		if (isEdit && preselectedMatchings.length > 0) {
		$('#matchingSelect').val(preselectedMatchings);
		}

		$('#matchingSelect').trigger('change');
		});
		}

		// 🔥 On change
		$('#designSelect').on('change', function () {
		loadMatchings($(this).val(), false);
		});

		// 🔥 On page load (EDIT MODE)
		const initialDesigns = $('#designSelect').val();

		if (initialDesigns && initialDesigns.length > 0) {
		loadMatchings(initialDesigns, true);
		}
		});
	</script>
}