$("#DesignId").on("change", function () {

    const designId = $(this).val();
    const matchingList = $("#MatchingList");

    matchingList.empty();

    if (!designId) {
        matchingList.append(`<div class="text-muted">Select design first</div>`);
        return;
    }

    $.get("/Program/GetMatchingByDesign", { designId: designId }, function (data) {

        matchingList.empty();

        $.each(data, function (i, item) {

            matchingList.append(`
                <div class="form-check">
                    <input class="form-check-input matching-checkbox"
                           type="checkbox"
                           name="SelectedMatchingIds"
                           value="${item.designMatchingId}"
                           id="matching_${item.designMatchingId}">

                    <label class="form-check-label" for="matching_${item.designMatchingId}">
                        Matching ${item.matchingNo} - ${item.plateName}
                    </label>
                </div>
            `);
        });
    });
});
</script>