@using Inventory.Domain.ViewModels
@model ProgramVM
@{
	ViewData["Title"] = ViewBag.Action + " Program";
	Layout = "~/Views/Shared/_Layout.cshtml";
	bool isEdit = Model.ProgramId > 0;
	// var DesignList = new SelectList(ViewBag.DesignList, "DesignId", "DesignNo", Model.DesignId);
}

<div class="card shadow-sm">
   
	<div class="card-header d-flex justify-content-between align-items-center">
		<h4 class="mb-0">@(isEdit ? "Edit" : "Add") Program <span class="text-danger">(@Model.ProgramNo)</span></h4>
		
		<a href="@Url.Action("Index", "Program")" class="btn btn-sm btn-outline-secondary">
			<i class="bi bi-arrow-left me-1"></i> Back
		</a>
	</div>

	<div class="card-body">
		<form asp-controller="Program" asp-action="Save" method="post" autocomplete="off" id="programForm"
			  enctype="multipart/form-data">

			@Html.AntiForgeryToken()
			@Html.HiddenFor(x => x.ProgramId)
			@Html.HiddenFor(x => x.ProgramNo)
			@Html.HiddenFor(x => x.Date)
			@Html.HiddenFor(x => x.PhotoFileName)


			@if (!ViewData.ModelState.IsValid)
			{
				<div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
			}

			<div class="row mb-3">

				<div class="col-md-4">
					<label class="form-label fw-semibold">Party <span class="text-danger">*</span></label>
					<select asp-for="PartyId" asp-items="ViewBag.PartyList" class="form-select">
						<option value="">-- Select Party --</option>
					</select>
					<span asp-validation-for="PartyId" class="text-danger"></span>
				</div>

				<div class="col-md-4">
					<label class="form-label fw-semibold">Designs <span class="text-danger">*</span></label>
					<select id="designSelect" name="SelectedDesignIds" class="form-select" multiple>
						@foreach (var item in ViewBag.DesignList)
						{
							var isSelected = Model.SelectedDesignIds != null
											 && Model.SelectedDesignIds.Contains(int.Parse(item.Value));

							<option value="@item.Value" selected="@(isSelected)">
								@item.Text
							</option>
						}
					</select>
					<span asp-validation-for="SelectedDesignIds" class="text-danger"></span>
				</div>

				<div class="col-md-4">
					<label class="form-label fw-semibold">Matchings <span class="text-danger">*</span></label>
					<select id="matchingSelect" name="SelectedMatchings" class="form-select" multiple>
					</select>
					<span asp-validation-for="SelectedMatchings" class="text-danger"></span>
				</div>
			</div>

			<div class="row mb-3">
				<div class="col-md-4">
					<label class="form-label fw-semibold">Quality</label>
					<input asp-for="Quality" type="text" class="form-control" placeholder="Enter Quality" />
					<span asp-validation-for="Quality" class="text-danger"></span>
				</div>

				<div class="col-md-4">
					<label class="form-label fw-semibold">Main Cut</label>
					<input asp-for="MainCut" type="number" class="form-control" placeholder="Enter Main Cut" />
					<span asp-validation-for="MainCut" class="text-danger"></span>
				</div>

				<div class="col-md-4">
					<label class="form-label fw-semibold">Fold</label>
					<input asp-for="Fold" type="text" class="form-control" placeholder="Enter Fold" />
					<span asp-validation-for="Fold" class="text-danger"></span>
				</div>
			</div>

			<div class="row mb-3">
				<div class="col-md-4">
					<label class="form-label fw-semibold">Finishing</label>
					<input asp-for="Finishing" type="text" class="form-control" placeholder="Enter Finishing" />
					<span asp-validation-for="Finishing" class="text-danger"></span>
				</div>

				<div class="col-md-4">
					<label class="form-label fw-semibold">Round</label>
					<input asp-for="Round" type="number" class="form-control" placeholder="Enter Round" />
					<span asp-validation-for="Round" class="text-danger"></span>
				</div>

				<div class="col-md-4">
					<label class="form-label fw-semibold">Rate</label>
					<input asp-for="Rate" class="form-control" placeholder="Enter Rate" />
					<span asp-validation-for="Rate" class="text-danger"></span>
				</div>
			</div>

			<div class="row mb-3">
				<div class="col-md-4">
					<label class="form-label fw-semibold">Quantity</label>
					<input asp-for="Quantity" type="number" class="form-control" placeholder="Enter Quantity" />
					<span asp-validation-for="Quantity" class="text-danger"></span>
				</div>

				<div class="col-md-6">
					<label class="form-label fw-semibold">Photo</label>
					<input asp-for="Photo" type="file" accept="image/*" class="form-control" />
					<small class="form-text text-muted g-font-size-default g-mt-0">
						(<i><b class="text-danger">Note:</b> Maximum size allowed 3 MB & File must be in .png, .jpg, .jpeg format only.</i>)
					</small>
					<span asp-validation-for="Photo" class="text-danger"></span>
				</div>

				@if (!string.IsNullOrEmpty(Model?.PhotoFileName))
				{
					<div class="mt-2">
						<img src="~/uploads/programs/@Model.PhotoFileName" style="max-height:120px;" class="img-thumbnail" />
					</div>
				}
			</div>

			<div class="row mb-3">
				<div class="col-12">
					<label class="form-label fw-semibold">Remarks</label>
					<textarea asp-for="Remarks" class="form-control" placeholder="Enter Remarks"></textarea>
					<span asp-validation-for="Remarks" class="text-danger"></span>
				</div>
			</div>

			<hr />

			<div class="d-flex gap-2 mt-3">
				<button type="submit" class="btn btn-primary px-4">
					@(isEdit ? "Update" : "Save")
				</button>
				<a asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
			</div>

		</form>
	</div>
</div>

@section Scripts {
	@{
		await Html.RenderPartialAsync("_ValidationScriptsPartial");
	}

