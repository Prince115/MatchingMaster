@using Inventory.Domain.ViewModels
@model ProgramVM
@{
	ViewData["Title"] = ViewBag.Action + " Program";
	Layout = "~/Views/Shared/_Layout.cshtml";
	bool isEdit = Model.ProgramId > 0;
	var DesignList = new SelectList(ViewBag.DesignList, "DesignId", "DesignNo", Model.DesignId);

}

<div class="card shadow-sm">
   
	<div class="card-header d-flex justify-content-between align-items-center">
		<h4 class="mb-0">@(isEdit ? "Edit" : "Add") Program <span class="text-danger">(@Model.ProgramNo)</span></h4>
		
		<a href="@Url.Action("Index", "Program")" class="btn btn-sm btn-outline-secondary">
			<i class="bi bi-arrow-left me-1"></i> Back
		</a>
	</div>

	<div class="card-body">
		<form asp-controller="Program" asp-action="Save" method="post" autocomplete="off" id="programForm">

			@Html.AntiForgeryToken()
			@Html.HiddenFor(x => x.ProgramId)
			@Html.HiddenFor(x => x.ProgramNo)
			@Html.HiddenFor(x => x.Date)

			@if (!ViewData.ModelState.IsValid)
			{
				<div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
			}

			<div class="row mb-3">
				<div class="col-md-3">
					<label class="form-label fw-semibold">Party <span class="text-danger">*</span></label>
					<select asp-for="PartyId" asp-items="ViewBag.PartyList" class="form-select">
						<option value="">-- Select Party --</option>
					</select>
					<span asp-validation-for="PartyId" class="text-danger"></span>
				</div>

				<div class="col-md-3">
					<label class="form-label fw-semibold">Design <span class="text-danger">*</span></label>
					<select asp-for="DesignId" asp-items="DesignList"
							class="form-select" id="DesignId">
						<option value="">-- Select Design --</option>
					</select>
					<span asp-validation-for="DesignId" class="text-danger"></span>
				</div>

				<div class="col-md-3">
					<label class="form-label fw-semibold">Matching <span class="text-danger">*</span></label>

					<div class="dropdown w-100">
						<button class="btn btn-outline-secondary w-100 text-start dropdown-toggle"
								type="button"
								data-bs-toggle="dropdown"
								aria-expanded="false"
								id="matchingDropdownBtn">
							Select Matching
						</button>
						<div class="dropdown-menu p-2"
							 id="MatchingList"
							 style="width:300px !important; max-height:220px; overflow-y:auto;">
						</div>
					</div>
					<span asp-validation-for="SelectedMatchingNo" class="text-danger"></span>
				</div>

				<div class="col-md-3">
					<label class="form-label fw-semibold">Quality</label>
					<input asp-for="Quality" type="text" class="form-control" placeholder="Enter Quality" />
					<span asp-validation-for="Quality" class="text-danger"></span>
				</div>
			</div>

			<div class="row mb-3">
				<div class="col-md-3">
					<label class="form-label fw-semibold">Main Cut</label>
					<input asp-for="MainCut" type="number" class="form-control" placeholder="Enter Main Cut" />
					<span asp-validation-for="MainCut" class="text-danger"></span>
				</div>

				<div class="col-md-3">
					<label class="form-label fw-semibold">Fold</label>
					<input asp-for="Fold" type="text" class="form-control" placeholder="Enter Fold" />
					<span asp-validation-for="Fold" class="text-danger"></span>
				</div>

				<div class="col-md-3">
					<label class="form-label fw-semibold">Finishing</label>
					<input asp-for="Finishing" type="text" class="form-control" placeholder="Enter Finishing" />
					<span asp-validation-for="Finishing" class="text-danger"></span>
				</div>

				<div class="col-md-3">
					<label class="form-label fw-semibold">Round</label>
					<input asp-for="Round" type="number" class="form-control" placeholder="Enter Round" />
					<span asp-validation-for="Round" class="text-danger"></span>
				</div>
			</div>

			<div class="row mb-3">
				<div class="col-md-3">
					<label class="form-label fw-semibold">Rate</label>
					<input asp-for="Rate" class="form-control" placeholder="Enter Rate" />
					<span asp-validation-for="Rate" class="text-danger"></span>
				</div>

				<div class="col-md-3">
					<label class="form-label fw-semibold">Quantity</label>
					<input asp-for="Quantity" type="number" class="form-control" placeholder="Enter Quantity" />
					<span asp-validation-for="Quantity" class="text-danger"></span>
				</div>

			</div>

			<div class="row mb-3">
				<div class="col-12">
					<label class="form-label fw-semibold">Remarks</label>
					<textarea asp-for="Remarks" class="form-control" placeholder="Enter Remarks"></textarea>
					<span asp-validation-for="Remarks" class="text-danger"></span>
				</div>
			</div>

			<hr />

			<div class="d-flex gap-2 mt-3">
				<button type="submit" class="btn btn-primary px-4">
					@(isEdit ? "Update" : "Save")
				</button>
				<a asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
			</div>

		</form>
	</div>
</div>

@section Scripts {
	@{
		await Html.RenderPartialAsync("_ValidationScriptsPartial");
	}

	<script>
		var selectedMatchings = @Html.Raw(Json.Serialize(Model.SelectedMatchingNo ?? new List<int>()));

		$(document).on("click", "#MatchingList", function (e) {
			e.stopPropagation();
		});

		function loadMatchings(designId) {

			const matchingList = $("#MatchingList");
			matchingList.empty();

			if (!designId) {
				matchingList.append(`<div class="text-muted small px-1">Select design first</div>`);
				updateDropdownBtn();
				return;
			}

			matchingList.html(`<div class="text-muted small px-1">Loading...</div>`);

			$.get("/Program/GetMatchingByDesign", { designId: designId }, function (data) {

				matchingList.empty();

				if (!data || data.length === 0) {
					matchingList.append(`<div class="text-muted small px-1">No matchings found</div>`);
					return;
				}

				$.each(data, function (i, item) {

					const checked = selectedMatchings.includes(item.matchingNo) ? "checked" : "";

					matchingList.append(`
						<div class="form-check">
							<input class="form-check-input matching-checkbox"
								   type="checkbox"
								   name="SelectedMatchingNo"
								   value="${item.matchingNo}"
								   id="matching_${item.matchingNo}"
								   ${checked} />
							<label class="form-check-label" for="matching_${item.matchingNo}">
								Matching - ${item.matchingNo}
							</label>
						</div>`);
				});

				updateDropdownBtn();
			});
		}

		function updateDropdownBtn() {
			const count = $(".matching-checkbox:checked").length;
			$("#matchingDropdownBtn").text(
				count > 0 ? count + " Matching Selected" : "Select Matching"
			);
		}

		$(document).on("change", ".matching-checkbox", function () {
			updateDropdownBtn();
			$("#matchingValidationMsg").hide();
		});

		$("#DesignId").on("change", function () {
			selectedMatchings = [];
			loadMatchings($(this).val());
		});

		$(document).ready(function () {
			const designId = $("#DesignId").val();
			if (designId) loadMatchings(designId);
		});

		// $("#programForm").on("submit", function (e) {
		// 	const checked = $(".matching-checkbox:checked").length;
		// 	if (checked === 0) {
		// 		e.preventDefault();
		// 		$("#matchingValidationMsg").show();
		// 		return false;
		// 	}
		// });
	</script>
}