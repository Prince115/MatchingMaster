@using Inventory.Domain.ViewModels
@model ProgramVM

@{
    Layout = "~/Views/Shared/_Layout_Print.cshtml";

    ViewBag.PageSize = "A4";
    ViewBag.PageOrientation = "portrait";
    ViewBag.PageMargin = "8mm 10mm 8mm 10mm";
    ViewBag.FontSize = "12pt";
    ViewData["Title"] = "Program - " + Model.ProgramNo;

    var vProgramMatching = ViewBag.MatchingList as List<ProgramMatchingVM> ?? new List<ProgramMatchingVM>();

    var vMatchingNoList = vProgramMatching.GroupBy(x => new { x.DesignId, x.MatchingNo }).Select(x => x.First()).ToList();
    var vDesignList = vProgramMatching.GroupBy(x => x.DesignId).Select(x => x.First()).ToList();
    var vPlateList = vProgramMatching.GroupBy(x => x.PlateId).Select(x => x.First()).ToList();
}

@section styles {
    <style>
        .text-theme {
            color: #c0544b !important
        }

        /* Hide elements with .no-print when printing */
        @@media print {
            .no-print {
                display: none !important;
            }
        }

    </style>
}


<div class="d-flex justify-content-end mb-2 no-print">
    <button id="btnPrint" type="button" class="btn btn-sm btn-primary me-2">
        <i class="bi bi-printer"></i> Print
    </button>
    <button id="btnDownload" type="button" class="btn btn-sm btn-secondary">
        <i class="bi bi-download"></i> Download PDF
    </button>
</div>

<div id="printContainer" class="border border-danger min-vh-100 p-3">

    <div class="row align-items-center mb-2">
        <div class="col-12">
            <div class="d-flex justify-content-between text-center text-theme small mb-1">
                <div>॥ SHREE HINGLAJ MATAJI ॥</div>
                <div>॥ SHREE GANESHAY NAMH ॥</div>
                <div>॥ SHREE SWAMINARAYAN ॥</div>
            </div>

            <div class="row mb-2 align-items-center">
                <div class="col-3 text-center">
                    <img src="~/assets/Images/logo.png" class="img-fluid" style="max-height:90px;">
                    </div>
                    <div class="col-3 text-center text-theme">
                        <div class="fw-bold" style="font-size:40px;">Mitshu</div>
                        <div class="fw-semibold">TEXTILE</div>
                    </div>
                    <div class="col-6">
                        <div class="border border-danger rounded p-2 small">
                            <table class="table table-sm table-borderless mb-0 align-middle">
                                <tr>
                                    <td class="text-theme" style="width:30px;">
                                        <i class="bi bi-telephone-fill"></i>
                                    </td>
                                    <td class="text-theme text-start">
                                        +91 94264 80404 | 94095 30045
                                    </td>
                                </tr>
                                <tr>
                                    <td class="text-theme">
                                        <i class="bi bi-geo-alt-fill"></i>
                                    </td>
                                    <td class="text-theme text-start">
                                        Khirasara road, Mahadev Nagar,<br>
                                        Street No.2, Jetpur 360 370
                                    </td>
                                </tr>
                                <tr>
                                    <td class="text-theme">
                                        <i class="bi bi-envelope-at-fill"></i>
                                    </td>
                                    <td class="text-theme text-start">
                                        mitshutextile@gmail.com
                                    </td>
                                </tr>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="row border-top border-bottom py-2 mb-3">
                    <div class="col-8 text-theme">
                        <strong>PARTY NAME :</strong> @Model.PartyName
                    </div>
                    <div class="col-4 text-theme text-end">
                        <strong>PROGRAM NO :</strong> @Model.ProgramNo
                    </div>
                </div>

                <div class="row">
                    <div class="col-6">
                        <table class="table table-bordered">
                            <thead class="text-theme text-center">
                                <tr>
                                    <th class="text-theme" colspan="2">PROGRAM DETAILS</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td class="text-theme">
                                        <b>Quality</b>
                                    </td>
                                    <td class="text-theme">@Model.Quality</td>
                                </tr>
                                <tr>
                                    <td class="text-theme"><b>Main Cut</b></td>
                                    <td class="text-theme">@Model.MainCut</td>
                                </tr>
                                <tr>
                                    <td class="text-theme"><b>Fold</b></td>
                                    <td class="text-theme">@Model.Fold</td>
                                </tr>
                                <tr>
                                    <td class="text-theme"><b>Finishing</b></td>
                                    <td class="text-theme">@Model.Finishing</td>
                                </tr>
                                <tr>
                                    <td class="text-theme"><b>Round</b></td>
                                    <td class="text-theme">@Model.Round</td>
                                </tr>
                                <tr>
                                    <td class="text-theme"><b>Rate</b></td>
                                    <td class="text-theme">@Model.Rate</td>
                                </tr>
                                <tr>
                                    <td class="text-theme"><b>Quantity</b></td>
                                    <td class="text-theme">@Model.Quantity</td>
                                </tr>
                                <tr>
                                    <td class="text-theme"><b>Remarks</b></td>
                                    <td class="text-theme">@Model.Remarks</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <div class="col-6">
                        <table class="table table-bordered">
                            <thead class="text-center">
                                <tr>
                                    <th class="text-theme">SUMMARY</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td class="text-theme"><b>Date :</b> @Model.Date.ToString("dd-MM-yyyy")</td>
                                </tr>
                                <tr>
                                    <td class="text-theme">
                                        <b>Matchings :</b>
                                        <br />
                                        <table class="table table-sm table-bordered mb-0">
                                            <thead>
                                                <tr>
                                                    <th class="text-theme">Design No</th>
                                                    <th class="text-theme">Matchings</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var vDesign in vDesignList)
                                                {
                                                    var matchings = vMatchingNoList
                                                        .Where(x => x.DesignId == vDesign.DesignId)
                                                        .OrderBy(o => o.MatchingNo)
                                                        .Select(m => "M-" + m.MatchingNo)
                                                        .ToList();
                                                    <tr>
                                                        <td class="text-theme"><b>@vDesign.DesignNo</b></td>
                                                        <td class="text-theme">@string.Join(", ", matchings)</td>
                                                    </tr>
                                                    <tr>
                                                        <td class="text-theme" colspan="2"></td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </td>
                                </tr>
								
                            </tbody>
                        </table>
                    </div>

                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.PhotoFileName))
            {
                <hr class="my-1" />
                <div class="row">
                    <div class="col-12 d-flex justify-content-center">
                        <img src="~/uploads/programs/@Model.PhotoFileName" style="max-height:200px;" class="" />
                    </div>
                </div>
            }
        </div>
    </div>

    @section scripts {
        <!-- html2pdf bundle -->
        <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.9.2/html2pdf.bundle.min.js"></script>
        <script>
            (function () {
            var btn = document.getElementById('btnPrint');
            var downloadBtn = document.getElementById('btnDownload');
            var element = document.getElementById('printContainer');
            var filename = '@($"Program-{Model.ProgramNo}.pdf")';
            var pageMargin = '@ViewBag.PageMargin';
            var pageSize = '@ViewBag.PageSize';
            var pageOrientation = '@ViewBag.PageOrientation';

            if (btn) {
            btn.addEventListener('click', function () {
            window.print();
            });
            }

            if (downloadBtn) {
            downloadBtn.addEventListener('click', function () {
            if (!window.html2pdf) {
            alert('PDF export library is not loaded.');
            return;
            }

            var marginVal = parseFloat(pageMargin) || 8;
            var opt = {
            margin: marginVal,
            filename: filename,
            image: { type: 'jpeg', quality: 0.98 },
            html2canvas: { scale: 2, useCORS: true },
            jsPDF: { unit: 'mm', format: pageSize && pageSize.toLowerCase() === 'a4' ? 'a4' : 'a4', orientation: pageOrientation || 'portrait' }
            };

            html2pdf().set(opt).from(element).save();
            });
            }
            })();
        </script>
    }
