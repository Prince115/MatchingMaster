@using Inventory.Domain.Entities
@model Inventory.Domain.ViewModels.PaginatedList<Party>
@{
	Layout = "~/Views/Shared/_Layout.cshtml";
}



<!-- Header -->
<div class="d-flex justify-content-between align-items-center mb-3">
	<h4 class="mb-0">Party List</h4>

	<a asp-action="AddEdit" class="btn btn-primary">
		<i class="bi bi-plus-lg"></i> Add Party
	</a>
</div>

<!-- Table -->
<div class="table-responsive">
	<table class="table table-bordered">
		<thead class="table-dark">
			<tr>
				<th class="text-center" style="width:70px;">#</th>
				<th>Name</th>
				<th>City</th>
				<th>State</th>
				<th class="text-center" style="width:150px;">Action</th>
			</tr>
		</thead>
		<tbody>
			@{
				int i = 0;
			}
			@foreach (var item in Model.Items)
			{
				i++;
				<tr>
					<td class="text-center">@i</td>
					<td>@item.PartyName</td>
					<td>@item.City</td>
					<td>@item.State</td>
					<td class="text-center">
						<a asp-action="AddEdit" asp-controller="Party" asp-route-id="@item.PartyId"
						   class="btn btn-sm btn-warning me-1">
							Edit
						</a>

						<a asp-action="Delete" asp-controller="Party" asp-route-id="@item.PartyId"
						   class="btn btn-sm btn-danger"
						   onclick="return confirm('Are you sure you want to delete this party?')">
							Delete
						</a>
					</td>
				</tr>
			}

			@if (!Model.Items.Any())
			{
				<tr>
					<td colspan="5" class="text-center text-muted">
						No records found
					</td>
				</tr>
			}
		</tbody>
	</table>
</div>