@using Inventory.Domain.Entities
@model Inventory.Domain.ViewModels.PaginatedList<Party>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="card shadow-sm">
    <!-- Header -->
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h4 class="mb-0">Party List</h4>

        <a asp-action="AddEdit" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> Add Party
        </a>
    </div>

    <!-- Table -->
    <div class="card-body">

        <div class="table-responsive">

            <table class="table table-bordered table-striped table-hover align-middle">

                <thead class="table-dark">
                    <tr>
                        <th class="text-center" style="width:70px;">#</th>
                        <th>Name</th>
                        <th>City</th>
                        <th>State</th>
                        <th class="text-center" style="width:150px;">Action</th>
                    </tr>
                </thead>

                <tbody>

                    @{
                        int i = (Model.PageIndex - 1) * Model.PageSize;
                    }

                    @if (Model.Items.Any())
                    {
                        foreach (var item in Model.Items)
                        {
                            i++;

                            <tr>
                                <td class="text-center">@i</td>
                                <td>@item.PartyName</td>
                                <td>@item.City</td>
                                <td>@item.State</td>

                                <td class="text-center">

                                    <a asp-action="AddEdit"
                                       asp-controller="Party"
                                       asp-route-id="@item.PartyId"
                                       class="btn btn-warning btn-sm me-1">
                                        <i class="bi bi-pencil"></i>
                                    </a>

                                    <a asp-action="Delete"
                                       asp-controller="Party"
                                       asp-route-id="@item.PartyId"
                                       class="btn btn-danger btn-sm"
                                       onclick="return confirm('Are you sure you want to delete this party?')">
                                        <i class="bi bi-trash"></i>
                                    </a>

                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">
                                No records found
                            </td>
                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

    <!-- Pagination -->
    <div class="card-footer bg-white">

        <nav>
            <ul class="pagination mb-0">

                <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@(Model.PageIndex - 1)"
                       asp-route-pageSize="@ViewBag.PageSize">
                        Previous
                    </a>
                </li>

                @for (int j = 1; j <= Model.TotalPages; j++)
                {
                    <li class="page-item @(j == Model.PageIndex ? "active" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-page="@j"
                           asp-route-pageSize="@ViewBag.PageSize">
                            @j
                        </a>
                    </li>
                }

                <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@(Model.PageIndex + 1)"
                       asp-route-pageSize="@ViewBag.PageSize">
                        Next
                    </a>
                </li>

            </ul>
        </nav>

    </div>

</div>
